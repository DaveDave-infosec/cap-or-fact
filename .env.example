PUBLIC_BASE_URL=https://your-render-url.onrender.com

# Optional, enables automated X founder/post crawling.
X_BEARER_TOKEN=replace_with_x_api_bearer_token

# Optional, enables Grok Scout with native X search.
XAI_API_KEY=replace_with_xai_api_key
XAI_MODEL=grok-4.3

# Optional, improves founder/project discovery.
GOOGLE_SEARCH_API_KEY=replace_with_google_custom_search_key
GOOGLE_SEARCH_CX=replace_with_google_programmable_search_engine_id

# Optional, only set this if your provider exposes an X-compatible API elsewhere.
# X_API_BASE_URL=https://api.x.com
# XAI_API_BASE_URL=https://api.x.ai/v1
